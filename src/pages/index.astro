---
// index.astro — Dark Brutalist Frost Showcase
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>// Naina Da Kya Kasoor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300;1,600&family=Inter:wght@300;400;800&family=Space+Mono&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-pure: #0a0a0a;
      --text-main: #f5f3ee;
      --text-muted: #6b6760;
      /* Intense Frost Variables */
      --glass-bg: rgba(20, 20, 20, 0.55);
      --glass-border: rgba(255, 255, 255, 0.12);
      --glass-shadow: 0 30px 60px rgba(0, 0, 0, 0.8);
      
      --font-display: 'Inter', sans-serif;
      --font-serif: 'Cormorant Garamond', serif;
      --font-mono: 'Space Mono', monospace;
    }

    html, body {
      height: 100%;
      width: 100%;
      overflow: hidden;
      background: var(--bg-pure);
      color: var(--text-main);
      -webkit-font-smoothing: antialiased;
    }

    /* ─── HEAVY BRUTALIST NOISE ─── */
    .noise-layer {
      position: fixed;
      inset: 0;
      z-index: 1;
      opacity: 0.05;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }

    /* ─── HALFTONE / GRID ACCENTS (Longshot vibe) ─── */
    .brutalist-grid {
      position: fixed;
      inset: 0;
      z-index: 0;
      background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      background-size: 50px 50px;
      pointer-events: none;
    }

    .halftone-corner {
      position: fixed;
      bottom: 0;
      right: 0;
      width: 40vw;
      height: 60vh;
      z-index: 0;
      opacity: 0.15;
      background-image: radial-gradient(circle, var(--text-main) 2px, transparent 2.5px);
      background-size: 12px 12px;
      clip-path: polygon(100% 0, 100% 100%, 0 100%);
      pointer-events: none;
    }

    /* ─── BACKGROUND TYPOGRAPHY ─── */
    .bg-text-container {
      position: absolute;
      top: 45%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 100vw;
      text-align: center;
      z-index: 2;
      pointer-events: none;
    }

    .massive-title {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: clamp(6rem, 16vw, 15rem);
      line-height: 0.75;
      letter-spacing: -0.05em;
      text-transform: uppercase;
      color: var(--text-main);
      white-space: nowrap;
    }

    .serif-accent {
      font-family: var(--font-serif);
      font-weight: 300;
      font-style: italic;
      font-size: clamp(3rem, 8vw, 7rem);
      color: var(--text-muted);
      display: block;
      margin-top: -0.2em;
      letter-spacing: 0;
    }

    /* ─── META INFO (Top Corners) ─── */
    .meta-top {
      position: fixed;
      top: 3rem;
      width: 100%;
      padding: 0 4rem;
      display: flex;
      justify-content: space-between;
      z-index: 10;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    /* ─── FLOATING FROSTED PLAYER PILL ─── */
    .player-wrapper {
      position: absolute;
      bottom: 4rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 20;
      width: min(900px, 90vw);
    }

    .frosted-pill {
      background: var(--glass-bg);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border: 1px solid var(--glass-border);
      border-top: 1px solid rgba(255, 255, 255, 0.2); /* Highlight edge for extra depth */
      border-radius: 100px;
      padding: 1.25rem 2.5rem;
      box-shadow: var(--glass-shadow);
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    /* ─── CONTROLS ─── */
    .play-btn {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--text-main);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      flex-shrink: 0;
    }

    .play-btn:hover { transform: scale(1.05); background: #ffffff; }
    .play-btn svg { width: 18px; height: 18px; fill: var(--bg-pure); }

    /* Track/Waveform container */
    .track-info {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .waveform-wrap {
      position: relative;
      height: 40px;
      width: 100%;
      cursor: pointer;
    }

    #waveform {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* Scrub overlay */
    .progress-overlay {
      position: absolute;
      inset: 0;
      z-index: 2;
    }
    
    .progress-line {
      position: absolute;
      top: 50%;
      left: 0;
      height: 2px;
      background: var(--text-main);
      width: 0%;
      transform: translateY(-50%);
      pointer-events: none;
      transition: width 0.1s linear;
    }

    /* Time & Labels */
    .time-row {
      display: flex;
      justify-content: space-between;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      color: var(--text-muted);
    }

    /* ─── PLAYING STATE ─── */
    .play-btn.playing .icon-play { display: none; }
    .play-btn.playing .icon-pause { display: block; }
    .play-btn:not(.playing) .icon-play { display: block; }
    .play-btn:not(.playing) .icon-pause { display: none; }

    @media (max-width: 768px) {
      .frosted-pill { padding: 1rem 1.5rem; gap: 1rem; border-radius: 24px; flex-direction: column; }
      .meta-top { padding: 0 1.5rem; top: 1.5rem; }
      .waveform-wrap { height: 30px; }
      .play-btn { width: 48px; height: 48px; }
    }
  </style>
</head>
<body>

  <div class="brutalist-grid"></div>
  <div class="halftone-corner"></div>
  <div class="noise-layer"></div>

  <header class="meta-top">
    <div>Vol 01.</div>
    <div>Acoustic // Raw</div>
  </header>

  <main class="bg-text-container">
    <h1 class="massive-title">Naina Da</h1>
    <span class="serif-accent">Kya Kasoor</span>
  </main>

  <div class="player-wrapper">
    <div class="frosted-pill">
      
      <button class="play-btn" id="play-btn" aria-label="Play / Pause">
        <svg class="icon-play" viewBox="0 0 24 24"><polygon points="7,4 20,12 7,20"/></svg>
        <svg class="icon-pause" viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      </button>

      <div class="track-info">
        <div class="time-row">
          <span>Your Guitarist</span>
          <span><span id="time-current">0:00</span> / <span id="time-total">—</span></span>
        </div>
        
        <div class="waveform-wrap" id="waveform-wrap">
          <canvas id="waveform"></canvas>
          <div class="progress-overlay" id="progress-track">
            <div class="progress-line" id="progress-line"></div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <audio id="audio" preload="metadata" crossorigin="anonymous">
    <source src="https://res.cloudinary.com/df6yxni8e/video/upload/Naina_Da_Kya_Kasoor_fkarmf.m4a" type="audio/mp4" />
  </audio>

  <script>
    const audio = document.getElementById('audio');
    const playBtn = document.getElementById('play-btn');
    const progressLine = document.getElementById('progress-line');
    const progressTrack = document.getElementById('progress-track');
    const timeCurrent = document.getElementById('time-current');
    const timeTotal = document.getElementById('time-total');
    const waveformCanvas = document.getElementById('waveform');
    const ctx = waveformCanvas.getContext('2d');

    let audioCtx, analyser, source;
    const BAR_COUNT = 70;

    function fmt(s) {
      if (isNaN(s)) return "0:00";
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60).toString().padStart(2, '0');
      return `${m}:${sec}`;
    }

    function setupAudio() {
      if (audioCtx) return;
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 256;
      source = audioCtx.createMediaElementSource(audio);
      source.connect(analyser);
      analyser.connect(audioCtx.destination);
      drawBars();
    }

    function drawBars() {
      requestAnimationFrame(drawBars);
      if (!analyser) return;

      const W = waveformCanvas.width;
      const H = waveformCanvas.height;
      const data = new Uint8Array(analyser.frequencyBinCount);
      analyser.getByteFrequencyData(data);

      ctx.clearRect(0, 0, W, H);
      const barW = (W / BAR_COUNT) - 2;

      for (let i = 0; i < BAR_COUNT; i++) {
        const v = data[Math.floor(i * data.length / BAR_COUNT)] / 255;
        const h = audio.paused ? (2 + Math.random() * 2) : Math.max(2, v * H);
        const x = i * (barW + 2);
        
        // Switched bars to light cream to pop against the dark mode
        const alpha = audio.paused ? 0.2 : (0.4 + v * 0.6);
        ctx.fillStyle = `rgba(245, 243, 238, ${alpha})`;
        
        ctx.fillRect(x, (H / 2) - (h / 2), barW, h);
      }
    }

    function resizeCanvas() {
      const wrap = document.getElementById('waveform-wrap');
      waveformCanvas.width = wrap.clientWidth;
      waveformCanvas.height = wrap.clientHeight;
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    playBtn.addEventListener('click', () => {
      setupAudio();
      if (audioCtx.state === 'suspended') audioCtx.resume();
      if (audio.paused) {
        audio.play();
        playBtn.classList.add('playing');
      } else {
        audio.pause();
        playBtn.classList.remove('playing');
      }
    });

    audio.addEventListener('timeupdate', () => {
      if (!audio.duration) return;
      const pct = (audio.currentTime / audio.duration) * 100;
      progressLine.style.width = pct + '%';
      timeCurrent.textContent = fmt(audio.currentTime);
    });

    audio.addEventListener('loadedmetadata', () => {
      timeTotal.textContent = fmt(audio.duration);
    });

    audio.addEventListener('ended', () => {
      playBtn.classList.remove('playing');
      progressLine.style.width = '0%';
    });

    progressTrack.addEventListener('click', (e) => {
      if (!audio.duration) return;
      const rect = progressTrack.getBoundingClientRect();
      const pct = (e.clientX - rect.left) / rect.width;
      audio.currentTime = pct * audio.duration;
    });

    (function idleShimmer() {
      if (!analyser) {
        resizeCanvas();
        const W = waveformCanvas.width;
        const H = waveformCanvas.height;
        ctx.clearRect(0, 0, W, H);
        const barW = (W / BAR_COUNT) - 2;
        const t = Date.now() / 600;
        for (let i = 0; i < BAR_COUNT; i++) {
          const h = 4 + Math.sin(t + i * 0.2) * 4;
          ctx.fillStyle = 'rgba(245, 243, 238, 0.15)';
          ctx.fillRect(i * (barW + 2), (H / 2) - (h / 2), barW, h);
        }
        requestAnimationFrame(idleShimmer);
      }
    })();
  </script>
</body>
</html>
